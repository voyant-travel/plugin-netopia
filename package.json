{
  "name": "@voyant-travel/netopia-adapter",
  "version": "0.105.23",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./adapter": "./src/adapter.ts",
    "./plugin": "./src/plugin.ts",
    "./service": "./src/service.ts",
    "./types": "./src/types.ts",
    "./validation": "./src/validation.ts",
    "./voyant": "./src/voyant.ts",
    "./openapi/admin": "./openapi/admin/netopia.json"
  },
  "scripts": {
    "typecheck": "NODE_OPTIONS=--max-old-space-size=14336 tsc --noEmit",
    "check-types": "pnpm typecheck",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "build": "pnpm run clean && NODE_OPTIONS=--max-old-space-size=14336 tsc -p tsconfig.json",
    "verify:external-install": "node scripts/verify-external-install.mjs",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "@voyant-travel/core": "0.125.0",
    "@voyant-travel/finance": "0.164.0",
    "@voyant-travel/hono": "0.128.1",
    "@voyant-travel/notifications": "0.130.4",
    "@voyant-travel/payments": "0.2.1",
    "@voyant-travel/utils": "0.107.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@changesets/cli": "^2.31.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "files": [
    "dist",
    "openapi"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./client": {
        "types": "./dist/client.d.ts",
        "import": "./dist/client.js",
        "default": "./dist/client.js"
      },
      "./adapter": {
        "types": "./dist/adapter.d.ts",
        "import": "./dist/adapter.js",
        "default": "./dist/adapter.js"
      },
      "./plugin": {
        "types": "./dist/plugin.d.ts",
        "import": "./dist/plugin.js",
        "default": "./dist/plugin.js"
      },
      "./service": {
        "types": "./dist/service.d.ts",
        "import": "./dist/service.js",
        "default": "./dist/service.js"
      },
      "./types": {
        "types": "./dist/types.d.ts",
        "import": "./dist/types.js",
        "default": "./dist/types.js"
      },
      "./validation": {
        "types": "./dist/validation.d.ts",
        "import": "./dist/validation.js",
        "default": "./dist/validation.js"
      },
      "./voyant": {
        "types": "./dist/voyant.d.ts",
        "import": "./dist/voyant.js",
        "default": "./dist/voyant.js"
      },
      "./openapi/admin": "./openapi/admin/netopia.json"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/netopia-adapter.git"
  },
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=20"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "adapter",
    "manifest": "./voyant",
    "compatibleWith": {
      "framework": ">=0.35.0",
      "targets": [
        "node",
        "voyant-cloud"
      ],
      "modes": [
        "local",
        "managed-cloud",
        "self-hosted"
      ]
    }
  }
}
